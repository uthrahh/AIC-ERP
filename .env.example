DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (recommended for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=AIC-CIIC_erp
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Use sqlite for local dev without PostgreSQL:
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=AIC-CIIC@example.com
AIC-CIIC_CONTACT_PHONE=+91-0000000000
AIC-CIIC_CONTACT_EMAIL=contact@AIC-CIIC.example.com
AIC-CIIC_OFFICE_ADDRESS=AIC-CIIC Incubation Centre, University Campus
